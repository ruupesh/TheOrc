		{
			"name": "Agents",
			"description": "CRUD operations for remote A2A agents.",
			"item": [
				{
					"name": "List My Agents",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Agents list returned', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.be.an('array');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/agents",
							"host": ["{{base_url}}"],
							"path": ["agents"]
						},
						"description": "List all agents accessible to the current user:\n- Agents you own\n- Agents installed from the marketplace"
					}
				},
				{
					"name": "Create Agent",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('agent_id', json.id);",
									"    pm.test('Agent created', function () {",
									"        pm.expect(json.name).to.eql('my_custom_agent');",
									"        pm.expect(json.port).to.eql(9001);",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"my_custom_agent\",\n    \"description\": \"A custom AI agent that handles customer support queries and ticket management.\",\n    \"host\": \"http://localhost\",\n    \"port\": 9001,\n    \"agent_card_path\": \"/.well-known/agent.json\",\n    \"timeout\": 300,\n    \"full_history\": true,\n    \"authentication_flag\": true,\n    \"allow_conversation_history\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/agents",
							"host": ["{{base_url}}"],
							"path": ["agents"]
						},
						"description": "Register a new remote A2A agent.\n\n**Required fields:** name, description, host, port\n**Optional fields:** agent_card_path, timeout, full_history, authentication_flag, allow_conversation_history"
					}
				},
				{
					"name": "Get Agent by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/agents/{{agent_id}}",
							"host": ["{{base_url}}"],
							"path": ["agents", "{{agent_id}}"]
						},
						"description": "Get details of a specific agent by its UUID."
					}
				},
				{
					"name": "Update Agent",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Updated: A custom AI agent for advanced customer support with sentiment analysis.\",\n    \"timeout\": 600,\n    \"port\": 9002\n}"
						},
						"url": {
							"raw": "{{base_url}}/agents/{{agent_id}}",
							"host": ["{{base_url}}"],
							"path": ["agents", "{{agent_id}}"]
						},
						"description": "Update an agent you own. All fields are optional — only send the fields you want to change."
					}
				},
				{
					"name": "Delete Agent",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/agents/{{agent_id}}",
							"host": ["{{base_url}}"],
							"path": ["agents", "{{agent_id}}"]
						},
						"description": "Delete an agent you own. System agents cannot be deleted.\n\nReturns 204 No Content on success."
					}
				}
			]
		},
