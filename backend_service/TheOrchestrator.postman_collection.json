							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"MySecurePass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login with email & password. Returns a JWT token that is auto-saved to the `token` collection variable.\n\nAll subsequent requests use this token via Bearer auth."
					}
