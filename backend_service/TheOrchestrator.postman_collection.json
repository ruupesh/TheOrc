							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"timeout\": 60,\n    \"tool_filter\": [\"search\", \"lookup\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp-tools/{{mcp_tool_id}}",
							"host": ["{{base_url}}"],
							"path": ["mcp-tools", "{{mcp_tool_id}}"]
