					"name": "Create MCP Tool (sse)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"event_stream_tool\",\n    \"connection_type\": \"sse\",\n    \"url\": \"http://localhost:3001/sse\",\n    \"timeout\": 30,\n    \"sse_read_timeout\": 600,\n    \"authentication_flag\": true,\n    \"auth_token\": \"my-sse-server-token\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp-tools",
							"host": ["{{base_url}}"],
							"path": ["mcp-tools"]
