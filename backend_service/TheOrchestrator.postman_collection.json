		{
			"name": "Auth",
			"description": "User registration, login, and profile endpoints.",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('user_id', json.id);",
									"    pm.test('User registered successfully', function () {",
									"        pm.expect(json.email).to.exist;",
									"        pm.expect(json.username).to.exist;",
									"        pm.expect(json.id).to.exist;",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"username\": \"johndoe\",\n    \"password\": \"MySecurePass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new user account. No auth required.\n\n**Validation:**\n- email: valid email format\n- username: 3-100 characters\n- password: 8-128 characters"
					}
				},
