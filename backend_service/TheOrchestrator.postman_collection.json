							"raw": "{{base_url}}/mcp-tools/{{mcp_tool_id}}",
							"host": ["{{base_url}}"],
							"path": ["mcp-tools", "{{mcp_tool_id}}"]
						},
						"description": "Delete an MCP tool you own. System tools cannot be deleted.\n\nReturns 204 No Content on success."
					}
				}
			]
		},
		{
			"name": "Marketplace",
			"description": "Agentic marketplace — publish, browse, install, and manage agents.",
			"item": [
				{
					"name": "Publish Agent to Marketplace",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('listing_id', json.id);",
									"    pm.test('Agent published', function () {",
									"        pm.expect(json.title).to.exist;",
									"        pm.expect(json.is_published).to.be.true;",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"title\": \"Customer Support AI Agent\",\n    \"description\": \"An advanced customer support agent powered by AI. Handles ticket creation, sentiment analysis, and automated responses. Runs on port 9001 and exposes A2A protocol.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/marketplace/publish",
							"host": ["{{base_url}}"],
							"path": ["marketplace", "publish"]
						},
						"description": "Publish one of your agents to the marketplace for other users to discover and install.\n\n**Prerequisite:** Create an agent first, then use its ID here.\n\n**Validation:**\n- You must own the agent\n- Agent can only be published once"
					}
				},
				{
					"name": "Browse Marketplace",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Marketplace listings returned', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.be.an('array');",
									"    if (json.length > 0) {",
									"        pm.collectionVariables.set('listing_id', json[0].id);",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/marketplace",
							"host": ["{{base_url}}"],
							"path": ["marketplace"],
							"query": []
						},
						"description": "Browse all published agents in the marketplace.\n\n**Query params:**\n- `search` (optional): filter by title or description\n- `skip` (optional, default 0): pagination offset\n- `limit` (optional, default 50, max 100): page size"
					}
				},
				{
					"name": "Browse Marketplace (with search)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/marketplace?search=customer&limit=10",
							"host": ["{{base_url}}"],
							"path": ["marketplace"],
							"query": [
								{ "key": "search", "value": "customer" },
								{ "key": "limit", "value": "10" }
							]
						},
						"description": "Search the marketplace by keyword in title or description."
					}
				},
				{
					"name": "Get Listing Details",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/marketplace/{{listing_id}}",
							"host": ["{{base_url}}"],
							"path": ["marketplace", "{{listing_id}}"]
						},
						"description": "Get full details of a marketplace listing including agent info and publisher."
					}
				},
				{
					"name": "Install Agent from Marketplace",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('installation_id', json.id);",
									"    pm.test('Agent installed', function () {",
									"        pm.expect(json.listing_id).to.exist;",
									"        pm.expect(json.installed_at).to.exist;",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"listing_id\": \"{{listing_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/marketplace/install",
							"host": ["{{base_url}}"],
							"path": ["marketplace", "install"]
						},
						"description": "Install a marketplace agent into your orchestrator.\n\nThe agent runs on the publisher's infrastructure — your orchestrator calls it remotely via A2A protocol.\n\n**Validation:**\n- Cannot install your own agent\n- Cannot install the same agent twice"
					}
				},
				{
					"name": "My Installations",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/marketplace/installations/me",
							"host": ["{{base_url}}"],
							"path": ["marketplace", "installations", "me"]
						},
						"description": "List all agents you have installed from the marketplace."
					}
				},
				{
					"name": "Uninstall Agent",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/marketplace/installations/{{installation_id}}",
							"host": ["{{base_url}}"],
							"path": ["marketplace", "installations", "{{installation_id}}"]
						},
						"description": "Remove an installed marketplace agent from your orchestrator.\n\nReturns 204 No Content on success."
					}
				}
			]
		},
		{
			"name": "Chat",
			"description": "The main conversation endpoint — the only user-facing orchestrator API.",
			"item": [
				{
					"name": "Send Message",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Chat response received', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.role).to.eql('assistant');",
									"    pm.expect(json.session_id).to.exist;",
									"});"
