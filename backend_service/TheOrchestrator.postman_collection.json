							"path": ["mcp-tools"]
						},
						"description": "List all MCP tools owned by the current user."
					}
				},
				{
					"name": "Create MCP Tool (stdio)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('mcp_tool_id', json.id);",
									"    pm.test('MCP tool created', function () {",
									"        pm.expect(json.name).to.eql('my_custom_search');",
									"        pm.expect(json.connection_type).to.eql('stdio');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"my_custom_search\",\n    \"connection_type\": \"stdio\",\n    \"command\": \"npx\",\n    \"args\": [\"-y\", \"@modelcontextprotocol/server-brave-search\"],\n    \"env\": {\n        \"BRAVE_API_KEY\": \"your-brave-api-key-here\"\n    },\n    \"timeout\": 30,\n    \"authentication_flag\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp-tools",
							"host": ["{{base_url}}"],
							"path": ["mcp-tools"]
						},
						"description": "Register a new stdio-based MCP tool.\n\n**Required:** name, connection_type\n**Stdio fields:** command, args, env\n**Optional:** timeout, authentication_flag, tool_filter"
					}
				},
				{
					"name": "Create MCP Tool (streamable_http)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"remote_calculator\",\n    \"connection_type\": \"streamable_http\",\n    \"url\": \"http://localhost:3000/mcp\",\n    \"headers\": {\n        \"X-Custom-Header\": \"my-value\"\n    },\n    \"timeout\": 30,\n    \"sse_read_timeout\": 300,\n    \"authentication_flag\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp-tools",
							"host": ["{{base_url}}"],
							"path": ["mcp-tools"]
						},
						"description": "Register a remote MCP tool using Streamable HTTP connection.\n\n**Required:** name, connection_type, url\n**Optional:** headers, timeout, sse_read_timeout, authentication_flag"
					}
				},
